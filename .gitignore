# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/
packages/*/node_modules/

# ── Build outputs ─────────────────────────────────────────────────────────────
backend/dist/
frontend/dist/
packages/frontend-sdk/dist/
# packages/backend-sdk/dist/index.js es un shim escrito a mano — se mantiene en git

# ── Environment files ─────────────────────────────────────────────────────────
# backend/.env y frontend/.env contienen defaults de desarrollo y SÍ se commitean.
# Solo ignorar overrides locales y un posible .env en la raíz:
/.env
**/.env.local
**/.env.*.local
frontend/.env
backend/.env

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Tests / Coverage ──────────────────────────────────────────────────────────
coverage/
*.lcov

# ── TypeScript build info ─────────────────────────────────────────────────────
*.tsbuildinfo

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
*.swp
*.swo

# ── Premium extensions — código fuente en repo privado (scrumforge-extensions) ──
# Estos directorios existen localmente al clonar ambos repos en paralelo pero
# NO se commitean al repo público. Su código vive en scrumforge-extensions/.

# Frontend extensions
frontend/src/extensions/planning-poker/
frontend/src/extensions/wiki/
frontend/src/extensions/retrospective-premium/
frontend/src/extensions/advanced-reports/
frontend/src/extensions/ai/
frontend/src/extensions/integrations/
frontend/src/extensions/billing-stripe/

# Backend extensions (precautorio — actualmente solo existen en scrumforge-extensions)
backend/src/extensions/planning-poker/
backend/src/extensions/wiki/
backend/src/extensions/retrospective-premium/
backend/src/extensions/advanced-reports/
backend/src/extensions/ai/
backend/src/extensions/integrations/
backend/src/extensions/billing-stripe/
