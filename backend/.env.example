# ─────────────────────────────────────────────────────────────────────────────
# ScrumForge Backend — Plantilla de variables de entorno
# Copia este archivo a .env y completa los valores marcados con <CAMBIAR>.
# El archivo .env nunca debe subirse al repositorio (está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos (REQUERIDA) ─────────────────────────────────────────────────
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_base_de_datos

DATABASE_URL="postgresql://scrumforge:scrumforge123@localhost:5432/scrumforge"

# ── JWT (REQUERIDO) ───────────────────────────────────────────────────────────
# JWT_SECRET: secreto para firmar access tokens. Mínimo 32 caracteres.
# Generar uno seguro: openssl rand -base64 48

JWT_SECRET="<CAMBIAR — mínimo 32 caracteres aleatorios>"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# ── Servidor ──────────────────────────────────────────────────────────────────

NODE_ENV="development"          # development | production | test
PORT=4000

# URL pública del backend — usada en callbacks de OAuth y enlaces de email.
# En producción: https://api.tu-dominio.com
BACKEND_URL="http://localhost:4000"

# URL del frontend — usada para CORS y redirect post-login.
# En producción: https://tu-dominio.com
FRONTEND_URL="http://localhost:5173"

# ── Logging ───────────────────────────────────────────────────────────────────
# Niveles disponibles (de menor a mayor): trace | debug | info | warn | error | fatal
# En producción se recomienda "info" o "warn".

LOG_LEVEL="info"

# ── HTTPS ─────────────────────────────────────────────────────────────────────
# Controla cómo el backend aplica HTTPS. Valores:
#
#  off        — Sin enforcement. Recomendado para desarrollo local (por defecto).
#               HTTP funciona con normalidad.
#
#  proxy      — El reverse proxy (Caddy, Nginx, AWS ALB…) termina TLS y reenvía
#               al backend por HTTP interno con X-Forwarded-Proto: https.
#               El backend redirige (301) cualquier petición HTTP plana.
#               Usar con docker-compose.caddy.yml.
#
#  standalone — El backend levanta HTTPS directamente sin reverse proxy.
#               Requiere TLS_CERT_PATH y TLS_KEY_PATH.
#               También levanta un servidor HTTP en HTTP_PORT que redirige a HTTPS.
#               Útil en VPS o bare-metal sin Caddy/Nginx.

HTTPS_MODE=off

# Rutas a los archivos PEM del certificado TLS (solo cuando HTTPS_MODE=standalone).
#
# Con Let's Encrypt (Certbot):
#   TLS_CERT_PATH=/etc/letsencrypt/live/tu-dominio.com/fullchain.pem
#   TLS_KEY_PATH=/etc/letsencrypt/live/tu-dominio.com/privkey.pem
#
# Con certificado autofirmado para desarrollo/staging:
#   openssl req -x509 -newkey rsa:4096 -keyout key.pem -out cert.pem -days 365 -nodes -subj '/CN=localhost'
#   TLS_CERT_PATH=./cert.pem
#   TLS_KEY_PATH=./key.pem
#
# TLS_CERT_PATH=
# TLS_KEY_PATH=

# Puerto del servidor HTTP de redirección (solo cuando HTTPS_MODE=standalone).
# En producción con puertos estándar usar 80 (puede requerir root o CAP_NET_BIND_SERVICE).
# HTTP_PORT=80

# ── Google OAuth (opcional — habilita login con Google) ──────────────────────
# Crear credenciales en: https://console.cloud.google.com → APIs & Services → Credentials
# URI de redirección autorizado: http://localhost:4000/auth/google/callback (dev)
#                                https://api.tu-dominio.com/auth/google/callback (prod)

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email — Nodemailer (opcional — email transaccional vía SMTP) ──────────────
# Servicios soportados: Gmail, Outlook365, Zoho, SendGrid, Mailgun, etc.
# Ver lista completa en: https://nodemailer.com/smtp/well-known/
# Nota: evitar cuentas con autenticación de dos factores activada.

MAIL_SERVICE=
MAIL_USER=
MAIL_PASS=

# Email del remitente para notificaciones del sistema (ej. verificación de cuenta)
ADMIN_EMAIL=

# ── Email — Resend (opcional — tiene prioridad sobre Nodemailer si está definido)
# Alternativa más moderna a Nodemailer. Obtener API key en: https://resend.com

RESEND_API_KEY=

# ── Stripe Billing (opcional — habilita suscripciones y planes de pago) ───────
# Obtener claves en: https://dashboard.stripe.com/apikeys
# Ver guía completa de configuración en: STRIPE_SETUP.md
#
# Para probar webhooks en local sin URL pública:
#   1. Instalar Stripe CLI: https://stripe.com/docs/stripe-cli
#   2. Ejecutar en una terminal aparte: stripe listen --forward-to localhost:4000/webhooks/stripe
#   3. Copiar el whsec_... que imprime la CLI en STRIPE_WEBHOOK_SECRET
#   Tarjeta de prueba: 4242 4242 4242 4242 · cualquier fecha futura · cualquier CVC

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# IDs de precio de Stripe para cada plan (obtener en Dashboard → Products)
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# ── IA — Anthropic (opcional — habilita funciones de IA asistida) ─────────────
# Obtener API key en: https://console.anthropic.com
# Modelo usado: claude-haiku-4-5-20251001

ANTHROPIC_API_KEY=

# ── Integración GitHub (opcional — permite vincular repositorios a proyectos) ──
# Crear token en: https://github.com/settings/tokens (permisos: repo, read:org)

GITHUB_TOKEN=

# ── Notificaciones Slack (opcional — envía alertas al canal configurado) ───────
# Crear Incoming Webhook en: https://api.slack.com/apps → Incoming Webhooks

SLACK_WEBHOOK_URL=

# ── Redis (opcional — rate limiting compartido entre instancias) ───────────────
# Sin esta variable el rate limiting usa Map en memoria, lo que funciona
# correctamente en single-instancia pero no comparte contadores entre múltiples
# réplicas del servidor (Docker Swarm, Kubernetes, PM2 cluster).
# Ejemplo con Docker: redis://localhost:6379

REDIS_URL=

# ── Extensiones — control de activación ───────────────────────────────────────
# CSV de extensiones a cargar al arrancar el servidor.
#
# Si la variable NO está definida → el servidor activa TODAS las extensiones
#   disponibles en el monorepo (modo desarrollo permisivo).
#
# Si está vacía (ENABLED_EXTENSIONS=) → no se carga ninguna extensión.
#
# Para producción, listar explícitamente las que se quieren activar:
# ENABLED_EXTENSIONS=planning-poker,ai,integrations,advanced-reports,retrospective-premium,billing-stripe,wiki

ENABLED_EXTENSIONS=
