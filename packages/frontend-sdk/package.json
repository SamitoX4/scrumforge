{
  "name": "@scrumforge/frontend-sdk",
  "version": "1.0.0",
  "description": "ScrumForge frontend SDK — components, hooks and types for premium frontend extensions",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc --project tsconfig.build.json"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "^5.9.0"
  },
  "keywords": ["scrumforge", "extensions", "sdk", "frontend"],
  "repository": {
    "type": "git",
    "url": "https://github.com/SamitoX4/scrumforge.git",
    "directory": "packages/frontend-sdk"
  }
}
