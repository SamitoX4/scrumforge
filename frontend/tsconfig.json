{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@scrumforge/frontend-sdk": [
        "../packages/frontend-sdk/src/index.ts"
      ],
      "react": [
        "./node_modules/@types/react"
      ],
      "@scrumforge/frontend-ext-planning-poker": [
        "extensions/frontend-ext-planning-poker/src/index.ts",
        "../../scrumforge-extensions/packages/frontend-ext-planning-poker/src/index.ts",
        "src/extensions/_stub.ts"
      ],
      "@scrumforge/frontend-ext-ai": [
        "extensions/frontend-ext-ai/src/index.ts",
        "../../scrumforge-extensions/packages/frontend-ext-ai/src/index.ts",
        "src/extensions/_stub.ts"
      ],
      "@scrumforge/frontend-ext-advanced-reports": [
        "extensions/frontend-ext-advanced-reports/src/index.ts",
        "../../scrumforge-extensions/packages/frontend-ext-advanced-reports/src/index.ts",
        "src/extensions/_stub.ts"
      ],
      "@scrumforge/frontend-ext-retrospective-premium": [
        "extensions/frontend-ext-retrospective-premium/src/index.ts",
        "../../scrumforge-extensions/packages/frontend-ext-retrospective-premium/src/index.ts",
        "src/extensions/_stub.ts"
      ],
      "@scrumforge/frontend-ext-billing-stripe": [
        "extensions/frontend-ext-billing-stripe/src/index.ts",
        "../../scrumforge-extensions/packages/frontend-ext-billing-stripe/src/index.ts",
        "src/extensions/_stub.ts"
      ],
      "@scrumforge/frontend-ext-integrations": [
        "extensions/frontend-ext-integrations/src/index.ts",
        "../../scrumforge-extensions/packages/frontend-ext-integrations/src/index.ts",
        "src/extensions/_stub.ts"
      ],
      "@scrumforge/frontend-ext-wiki": [
        "extensions/frontend-ext-wiki/src/index.ts",
        "../../scrumforge-extensions/packages/frontend-ext-wiki/src/index.ts",
        "src/extensions/_stub.ts"
      ]
    },
    "types": []
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/tests"
  ],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}
